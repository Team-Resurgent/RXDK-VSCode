# Shell scripts must stay LF so they run on Linux/macOS regardless of the
# platform they were checked out or packaged on. With core.autocrlf=true on
# Windows these would otherwise become CRLF, and the `#!/usr/bin/env bash\r`
# shebang then fails with: /usr/bin/env: 'bash\r': No such file or directory.
*.sh text eol=lf

# Windows batch files are the opposite -- keep them CRLF.
*.cmd text eol=crlf
*.bat text eol=crlf
