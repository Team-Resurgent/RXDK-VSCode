#!/bin/sh
# Reject commits that attribute authorship to Cursor Agent (GitHub counts Co-authored-by as a contributor).
if grep -Eq '^Co-authored-by:[[:space:]]*Cursor[[:space:]]*<cursoragent@cursor\.com>[[:space:]]*$' "$1"; then
  echo "This commit message includes 'Co-authored-by: Cursor <cursoragent@cursor.com>'." >&2
  echo "Remove that line so only your identity appears on GitHub." >&2
  exit 1
fi
exit 0
