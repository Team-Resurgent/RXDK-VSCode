#!/bin/sh
# Cursor may inject Co-authored-by: Cursor <cursoragent@cursor.com> — strip it before commit completes.
file="$1"
[ -f "$file" ] || exit 0
tmp="${file}.rxdk-strip"
grep -Ev '^Co-authored-by:[[:space:]]*Cursor[[:space:]]*<cursoragent@cursor\.com>[[:space:]]*$' "$file" > "$tmp" && mv "$tmp" "$file"
exit 0
