{
  "name": "rxdk-vscode",
  "displayName": "RXDK",
  "description": "Original Xbox development: host tools, project templates, build, deploy, and debug (headers/libs from RXDK-SDK)",
  "version": "0.2.1",
  "icon": "media/extension-icon.png",
  "publisher": "rxdk-libs",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/Team-Resurgent/RXDK-VSCode.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Debuggers", "Other"],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/rxdk.project.json",
    "onDebugResolve:xbox",
    "onDebugInitialConfigurations",
    "onDebug:xbox"
  ],
  "main": "./dist/extension/extension.js",
  "contributes": {
    "commands": [
      { "command": "rxdk.setupPrerequisites", "title": "Complete Setup", "category": "RXDK", "icon": "$(warning)" },
      { "command": "rxdk.newProject", "title": "New Project", "category": "RXDK", "icon": "$(add)" },
      { "command": "rxdk.build", "title": "Build", "category": "RXDK", "icon": "$(tools)" },
      { "command": "rxdk.deploy", "title": "Deploy", "category": "RXDK", "icon": "$(cloud-upload)" },
      { "command": "rxdk.run", "title": "Run", "category": "RXDK", "icon": "$(run)" },
      { "command": "rxdk.debug", "title": "Debug", "category": "RXDK", "icon": "$(debug-alt)" },
      { "command": "rxdk.debugPrebuiltXbe", "title": "New Prebuilt XBE Project", "category": "RXDK", "icon": "$(file-binary)" },
      { "command": "rxdk.refreshPrebuiltSource", "title": "Refresh Source Folder", "category": "RXDK", "icon": "$(folder-opened)" },
      { "command": "rxdk.setXboxIp", "title": "Set Xbox IP / Hostname", "category": "RXDK" },
      { "command": "rxdk.showSidebar", "title": "Show RXDK Sidebar", "category": "RXDK", "icon": "$(list-tree)" },
      { "command": "rxdk.refreshSidebar", "title": "Refresh", "category": "RXDK", "icon": "$(refresh)" },
      { "command": "rxdk.openSdkDocs", "title": "Xbox SDK Documentation", "category": "RXDK", "icon": "$(book)" },
      { "command": "rxdk.openExtensionDocs", "title": "Extension Documentation", "category": "RXDK", "icon": "$(book)" },
      { "command": "rxdk.openSdkFolder", "title": "Open SDK Folder (include/lib)", "category": "RXDK", "icon": "$(folder-opened)" },
      { "command": "rxdk.openToolsFolder", "title": "Open Host Tools Folder", "category": "RXDK", "icon": "$(folder-opened)" },
      { "command": "rxdk.openDocsFolder", "title": "Open Documentation Folder", "category": "RXDK", "icon": "$(folder-opened)" },
      { "command": "rxdk.fetchLatestSdk", "title": "Fetch Latest RXDK-SDK", "category": "RXDK", "icon": "$(cloud-download)" },
      { "command": "rxdk.installDotNetRuntime", "title": "Install .NET 8 Runtime", "category": "RXDK", "icon": "$(cloud-download)" },
      { "command": "rxdk.launchXbwatson", "title": "Launch xbWatson", "category": "RXDK", "icon": "$(output)" },
      { "command": "rxdk.launchXbNeighborhood", "title": "Launch xbNeighborhood", "category": "RXDK", "icon": "$(files)" },
      { "command": "rxdk.openXboxNeighborhood", "title": "Open Xbox Neighborhood", "category": "RXDK", "icon": "$(root-folder)" },
      { "command": "rxdk.cycleGlobalsScope", "title": "Cycle Globals Visibility (Title / +Constants / All)", "category": "RXDK", "icon": "$(list-filter)" },
      { "command": "rxdk.setBuildType", "title": "Set Build Type (Debug / ReleaseSafe / ReleaseFast / ReleaseSmall)", "category": "RXDK", "icon": "$(settings-gear)" },
      { "command": "rxdk.openSettings", "title": "Settings", "category": "RXDK", "icon": "$(gear)" }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rxdk-sidebar",
          "title": "RXDK",
          "icon": "media/rxdk-icon.svg"
        }
      ]
    },
    "views": {
      "rxdk-sidebar": [
        {
          "id": "rxdk.explorer",
          "name": "RXDK"
        }
      ]
    },
    "menus": {
      "view/title": [
        { "command": "rxdk.setupPrerequisites", "when": "view == rxdk.explorer && !rxdk.prerequisitesReady", "group": "navigation" },
        { "command": "rxdk.newProject", "when": "view == rxdk.explorer && rxdk.prerequisitesReady", "group": "navigation" },
        { "command": "rxdk.refreshSidebar", "when": "view == rxdk.explorer", "group": "navigation" },
        { "command": "rxdk.openSettings", "when": "view == rxdk.explorer", "group": "navigation@99" }
      ],
      "commandPalette": [
        { "command": "rxdk.setupPrerequisites", "when": "!rxdk.prerequisitesReady" },
        { "command": "rxdk.build", "when": "rxdk.prerequisitesReady && rxdk.hasProject" },
        { "command": "rxdk.deploy", "when": "rxdk.prerequisitesReady && rxdk.hasProject" },
        { "command": "rxdk.run", "when": "rxdk.prerequisitesReady && rxdk.hasProject" },
        { "command": "rxdk.debug", "when": "rxdk.prerequisitesReady && rxdk.hasProject" },
        { "command": "rxdk.debugPrebuiltXbe", "when": "rxdk.prerequisitesReady" },
        { "command": "rxdk.newProject", "when": "rxdk.prerequisitesReady" },
        { "command": "rxdk.showSidebar", "when": "rxdk.prerequisitesReady" },
        { "command": "rxdk.openSdkDocs", "when": "rxdk.prerequisitesReady" },
        { "command": "rxdk.openExtensionDocs", "when": "rxdk.prerequisitesReady" },
        { "command": "rxdk.openSdkFolder", "when": "rxdk.prerequisitesReady" },
        { "command": "rxdk.openToolsFolder", "when": "rxdk.prerequisitesReady" },
        { "command": "rxdk.openDocsFolder", "when": "rxdk.prerequisitesReady" },
        { "command": "rxdk.fetchLatestSdk", "when": "rxdk.prerequisitesReady" },
        { "command": "rxdk.launchXbwatson", "when": "rxdk.prerequisitesReady" },
        { "command": "rxdk.launchXbNeighborhood", "when": "rxdk.prerequisitesReady" },
        { "command": "rxdk.openXboxNeighborhood", "when": "isWindows" },
        { "command": "rxdk.installDotNetRuntime", "when": "rxdk.prerequisitesReady" },
        { "command": "rxdk.cycleGlobalsScope", "when": "debugType == 'xbox'" },
        { "command": "rxdk.setBuildType", "when": "rxdk.prerequisitesReady && rxdk.hasProject" },
        { "command": "rxdk.openSettings", "when": "true" },
        { "command": "rxdk.refreshSidebar", "when": "false" },
        { "command": "rxdk.refreshPrebuiltSource", "when": "false" }
      ]
    },
    "debuggers": [
      {
        "type": "xbox",
        "label": "Xbox",
        "languages": ["cpp", "c"],
        "program": "./dist/debug/adapter.js",
        "runtime": "node",
        "configurationAttributes": {
          "launch": {
            "required": ["xbePath"],
            "properties": {
              "program": { "type": "string", "description": "Local Win32 .exe path (for PDB symbols). Optional; falls back to the XBE header when omitted." },
              "xbePath": { "type": "string", "description": "Remote Xbox path to .xbe" },
              "xbeDir": { "type": "string", "description": "Remote directory for DmSetTitle" },
              "xbeTitle": { "type": "string", "description": "Remote .xbe file name" },
              "xbe": { "type": "string", "description": "Local .xbe path used for symbol image size when no program (.exe) is provided" },
              "pdb": { "type": "string", "description": "Local .pdb path" },
              "map": { "type": "string", "description": "Local .map path (for globals)" },
              "srcRoot": { "type": "string", "description": "Source root for mapping PDB paths (defaults to the workspace folder)" },
              "consoleName": { "type": "string", "description": "Target Xbox console name" },
              "bridgePath": { "type": "string", "description": "Path to xboxdbg-bridge (managed Rxdk.XboxDbgBridge host)" },
              "reboot": { "type": "boolean", "default": false },
              "buildOnly": { "type": "boolean", "default": false, "description": "Run only preLaunchTask (build), then end the session immediately -- no deploy, no hardware launch, no attach." }
            }
          },
          "attach": {
            "properties": {
              "program": { "type": "string" },
              "pdb": { "type": "string" },
              "consoleName": { "type": "string" },
              "bridgePath": { "type": "string" }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "xbox",
            "request": "launch",
            "name": "Debug Xbox title",
            "preLaunchTask": "rxdk: build+deploy",
            "program": "${workspaceFolder}/out/my-game.exe",
            "xbePath": "xe:\\my-game\\my-game.xbe"
          },
          {
            "type": "xbox",
            "request": "launch",
            "name": "Build Xbox title",
            "preLaunchTask": "rxdk: build",
            "buildOnly": true,
            "xbePath": "xe:\\my-game\\my-game.xbe"
          }
        ]
      }
    ],
    "configuration": {
      "title": "RXDK",
      "properties": {
        "rxdk.sdkPath": {
          "type": "string",
          "default": "",
          "description": "Override bundled SDK path (default: extension sdk/)"
        },
        "rxdk.stagedSdkPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Override the persistent SDK clone directory (include/lib from [RXDK-SDK](https://github.com/Team-Resurgent/RXDK-SDK)). Default: `%ProgramData%\\RXDK\\sdk` (Windows), `~/.local/share/rxdk/sdk` (Linux), `~/Library/Application Support/RXDK/sdk` (macOS). Existing folders are never overwritten."
        },
        "rxdk.sdkGitUrl": {
          "type": "string",
          "default": "https://github.com/Team-Resurgent/RXDK-SDK.git",
          "description": "Git URL cloned on first launch when the SDK folder is missing."
        },
        "rxdk.docsGitUrl": {
          "type": "string",
          "default": "https://github.com/Team-Resurgent/RXDK-Docs.git",
          "markdownDescription": "Git URL for the documentation set ([RXDK-Docs](https://github.com/Team-Resurgent/RXDK-Docs): Xbox SDK reference + RXDK guide), cloned to `%ProgramData%\\RXDK\\docs`."
        },
        "rxdk.docsGitRef": {
          "type": "string",
          "default": "",
          "description": "Optional git branch or tag for the RXDK-Docs clone (default: repository default branch)."
        },
        "rxdk.stagedToolsPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Override the persistent host-tools directory (imagebld, xdvdfs, xbcp, debug tools) downloaded by the host-tools prerequisite. Default: `%ProgramData%\\RXDK\\tools` (Windows), `~/.local/share/rxdk/tools` (Linux), `~/Library/Application Support/RXDK/tools` (macOS)."
        },
        "rxdk.hostToolsTag": {
          "type": "string",
          "default": "",
          "markdownDescription": "Pin the [RXDK-Tools](https://github.com/Team-Resurgent/RXDK-Tools) release the host-tools prerequisite downloads (e.g. `build-78`). Empty = latest."
        },
        "rxdk.xdvdfsTag": {
          "type": "string",
          "default": "",
          "markdownDescription": "Pin the [xdvdfs](https://github.com/Team-Resurgent/xdvdfs) release the host-tools prerequisite downloads (e.g. `v0.8.3-TR`). Empty = latest."
        },
        "rxdk.sdkGitRef": {
          "type": "string",
          "default": "",
          "description": "Optional git branch or tag for the RXDK-SDK clone (default: repository default branch)."
        },
        "rxdk.autoInstallDotNetRuntime": {
          "type": "boolean",
          "default": false,
          "description": "When the .NET 8 runtime is missing outside the RXDK setup page, offer to download and install it automatically (deploy/debug host tools)."
        },
        "rxdk.xbwatsonPath": {
          "type": "string",
          "default": "",
          "description": "Path to xbwatson (default: the host-tools prerequisite download under …/RXDK/tools)."
        },
        "rxdk.defaultConsole": {
          "type": "string",
          "default": "",
          "markdownDescription": "Default Xbox IP or hostname.\n\n- **Windows:** leave empty to use the Xbox SDK registry (`HKCU\\Software\\Microsoft\\XboxSDK\\XboxName`, XBSetIP, or Neighborhood). Set this only to override the registry.\n- **macOS / Linux:** set here in workspace or user `settings.json` (no Windows registry)."
        },
        "rxdk.zigPath": {
          "type": "string",
          "default": "",
          "description": "Path to zig executable (default: PATH or RXDK-managed Zig from prerequisites install)"
        },
        "xbox.defaultConsole": {
          "type": "string",
          "default": "",
          "markdownDescription": "Alias for `#rxdk.defaultConsole#`. Windows: registry when empty; macOS/Linux: settings JSON."
        },
        "xbox.bridgePath": {
          "type": "string",
          "default": "",
          "description": "Path to xboxdbg-bridge (default: extension sdk/tools/xboxdbg-bridge.exe on Windows)"
        },
        "xbox.showTitleOutput": {
          "type": "boolean",
          "default": true,
          "description": "Reveal Output panel when title prints via OutputDebugStringA"
        },
        "rxdk.debugger.globalsScope": {
          "type": "string",
          "enum": ["title", "titleAndConstants", "all"],
          "enumDescriptions": [
            "Only the title's own mutable globals (recommended).",
            "Also show the title's compile-time constant tables (e.g. D3D lookup tables pulled in from headers).",
            "Also show statically-linked library globals (D3D/CRT internals). Verbose."
          ],
          "default": "title",
          "markdownDescription": "Which symbols appear in the debugger's **Globals** pane. Toggle live during a session with the **RXDK: Cycle Globals Visibility** command."
        },
        "rxdk.optimize": {
          "type": "string",
          "enum": ["Debug", "ReleaseSafe", "ReleaseFast", "ReleaseSmall"],
          "enumDescriptions": [
            "No optimization, full debug info -- the default.",
            "Optimized, but keeps runtime safety checks (traps on undefined behavior instead of a silent miscompile).",
            "Optimized for speed, no safety checks, no debug info.",
            "Optimized for size, no safety checks, no debug info."
          ],
          "default": "Debug",
          "markdownDescription": "Build type used by the **rxdk: build** task. Change it with the **RXDK: Set Build Type** command."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p . && tsc -p debug",
    "watch": "tsc -watch -p .",
    "package": "npx --yes @vscode/vsce package"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.65.0",
    "@vscode/debugprotocol": "^1.65.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
