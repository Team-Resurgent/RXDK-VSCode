.vscode/**
.vscode-test/**
src/**
debug/**
scripts/**
docs/**
external/**
vendor/**
.gitmodules
node_modules/**
!node_modules/@vscode/**
.gitignore
tsconfig.json
debug/tsconfig.json
**/*.ts

# Repo dev / CI (not extension runtime)
install-extension.cmd
.github/**
release/**

# Build outputs — never ship inside the VSIX
*.zip
*.vsix

dist/**
!dist/extension/**
!dist/debug/**
sdk/**
!sdk/VERSION.txt
sdk/include/**
sdk/lib/**
sdk/tools/**
sdk/test-xbcp/**
# `out/` at any depth -- root build dir AND template build dirs
# (templates/*/out/ from building a template in place). Bare `out/**` only
# matched the root, so template out/ (default.xbe, .obj, .exe, .pdb, .iso...)
# was leaking into the packaged VSIX.
**/out/**
